mjx-container[jax="SVG"] path[data-c], mjx-container[jax="SVG"] use[data-c] { stroke-width: 3; }
</style>
<script>
function showMod(name){
    document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
    document.getElementById('mod-'+name).classList.add('active');
    document.querySelectorAll('.nav-tab').forEach(t=>t.classList.remove('active'));
    document.querySelector(`[data-mod="${name}"]`).classList.add('active');
}
